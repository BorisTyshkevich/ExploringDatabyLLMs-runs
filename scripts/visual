#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${script_dir}/run-dir-wrapper.sh"

usage() {
  cat <<'EOF'
Usage: scripts/visual RUN_DIR [extra qforge visual flags]
   or: scripts/visual --run-dir RUN_DIR [extra qforge visual flags]

Run qforge visual from the ExploringDatabyLLMs-runs repo.

Examples:
  ./scripts/visual 2026-03-20/q001_hops_per_day/claude/opus/run-001
  ./scripts/visual /Users/bvt/work/ExploringDatabyLLMs-runs/2026-03-20/q001_hops_per_day/claude/opus/run-001
  ./scripts/visual --run-dir 2026-03-20/q001_hops_per_day/claude/opus/run-001 --skip-browser-live-fetch
EOF
}

qforge_run_dir_wrapper visual "scripts/visual" usage "$@"
