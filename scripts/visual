#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scripts/visual RUN_DIR [extra qforge process-visual flags]
   or: scripts/visual --run-dir RUN_DIR [extra qforge process-visual flags]

Run qforge process-visual from the ExploringDatabyLLMs-runs repo.

Examples:
  ./scripts/visual 2026-03-20/q001_hops_per_day/claude/opus/run-001
  ./scripts/visual /Users/bvt/work/ExploringDatabyLLMs-runs/2026-03-20/q001_hops_per_day/claude/opus/run-001
  ./scripts/visual --run-dir 2026-03-20/q001_hops_per_day/claude/opus/run-001 --skip-browser-live-fetch
EOF
}

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
runs_root="$(cd "${script_dir}/.." && pwd)"

if [[ $# -eq 0 ]]; then
  usage >&2
  exit 1
fi

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

args=("$@")
if [[ "${args[0]}" != "--run-dir" ]]; then
  args=(--run-dir "${args[0]}" "${args[@]:1}")
fi

run_dir=""
for ((i = 0; i < ${#args[@]}; i++)); do
  if [[ "${args[i]}" == "--run-dir" && $((i + 1)) -lt ${#args[@]} ]]; then
    run_dir="${args[i + 1]}"
    break
  fi
done

if [[ -z "$run_dir" ]]; then
  echo "scripts/visual requires a run directory" >&2
  usage >&2
  exit 1
fi

if [[ "$run_dir" != /* ]]; then
  run_dir="${runs_root}/${run_dir}"
fi

args_with_path=()
skip_next=0
for ((i = 0; i < ${#args[@]}; i++)); do
  if [[ $skip_next -eq 1 ]]; then
    skip_next=0
    continue
  fi
  if [[ "${args[i]}" == "--run-dir" && $((i + 1)) -lt ${#args[@]} ]]; then
    args_with_path+=(--run-dir "$run_dir")
    skip_next=1
    continue
  fi
  args_with_path+=("${args[i]}")
done

exec "${script_dir}/gforge" process-visual -v "${args_with_path[@]}"
