I’ve confirmed the core grouping pattern: the maximum is 8 hops in a day for a single tail number on a single flight number, and some of those are clearly repeated. I’m refining the final statement now so the returned rows already carry enough context for the report template to describe repetition, the most recent max-hop itinerary, and route clustering.
tool altinity_ontime_demo.execute_query({"query":"WITH legs AS (SELECT Tail_Number, Flight_Number_Reporting_Airline, IATA_CODE_Reporting_Airline, FlightDate, OriginAirportID, DestAirportID, toDateTime(concat(toString(FlightDate), ' ', leftPad(toString(intDiv(DepTime, 100)), 2, '0'), ':', leftPad(toString(DepTime % 100), 2, '0'), ':00')) AS dep_ts, concat(leftPad(toString(intDiv(DepTime, 100)), 2, '0'), ':', leftPad(toString(DepTime % 100), 2, '0')) AS dep_hhmm, oa.code AS origin_code, da.code AS dest_code FROM ontime.ontime INNER JOIN ontime.airports_latest AS oa ON ontime.ontime.OriginAirportID = oa.airport_id INNER JOIN ontime.airports_latest AS da ON ontime.ontime.DestAirportID = da.airport_id WHERE Cancelled = 0 AND Diverted = 0 AND DepTime IS NOT NULL AND Tail_Number != '' AND Flight_Number_Reporting_Airline != ''), itineraries AS (SELECT Tail_Number, Flight_Number_Reporting_Airline, IATA_CODE_Reporting_Airline, FlightDate, count() AS Hops, arraySort(x -> (x.1, x.2, x.3), groupArray((dep_ts, toString(origin_code), toString(dest_code), dep_hhmm))) AS ordered_legs, arrayStringConcat(arrayConcat([ordered_legs[1].2], arrayMap(x -> x.3, ordered_legs)), ' -> ') AS Route, arrayStringConcat(arrayMap(x -> concat(x.4, ' ', x.2), ordered_legs), ' | ') AS Departure_Times_From_Origin FROM legs GROUP BY Tail_Number, Flight_Number_Reporting_Airline, IATA_CODE_Reporting_Airline, FlightDate), ranked AS (SELECT Tail_Number, Flight_Number_Reporting_Airline, IATA_CODE_Reporting_Airline, FlightDate, Hops, Route, Departure_Times_From_Origin, max(Hops) OVER () AS Max_Hops_Overall, countIf(Hops = max(Hops) OVER ()) OVER () AS Max_Hop_Itinerary_Count, count() OVER (PARTITION BY Route) AS Route_Frequency_In_Top10_Candidate, row_number() OVER (ORDER BY Hops DESC, FlightDate DESC, Tail_Number DESC) AS itinerary_rank FROM itineraries) SELECT Tail_Number, Flight_Number_Reporting_Airline, IATA_CODE_Reporting_Airline, FlightDate, Hops, Route, Departure_Times_From_Origin, Max_Hops_Overall, Max_Hop_Itinerary_Count, Route_Frequency_In_Top10_Candidate FROM ranked ORDER BY Hops DESC, FlightDate DESC, Tail_Number DESC LIMIT 10","limit":20})
