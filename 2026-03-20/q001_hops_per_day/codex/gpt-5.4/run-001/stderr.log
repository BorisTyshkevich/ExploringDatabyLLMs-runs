{
  "sql": "WITH legs AS (\n    SELECT\n        o.Tail_Number,\n        o.Flight_Number_Reporting_Airline,\n        o.IATA_CODE_Reporting_Airline,\n        o.FlightDate,\n        toDateTime(\n            concat(\n                toString(o.FlightDate),\n                ' ',\n                leftPad(toString(intDiv(o.DepTime, 100)), 2, '0'),\n                ':',\n                leftPad(toString(o.DepTime % 100), 2, '0'),\n                ':00'\n            )\n        ) AS dep_ts,\n        concat(\n            leftPad(toString(intDiv(o.DepTime, 100)), 2, '0'),\n            ':',\n            leftPad(toString(o.DepTime % 100), 2, '0')\n        ) AS dep_hhmm,\n        o.Origin,\n        o.Dest\n    FROM ontime.ontime AS o\n    WHERE o.Cancelled = 0\n      AND o.Diverted = 0\n      AND o.DepTime IS NOT NULL\n      AND o.Tail_Number != ''\n      AND o.Flight_Number_Reporting_Airline != ''\n),\nitineraries AS (\n    SELECT\n        Tail_Number,\n        Flight_Number_Reporting_Airline,\n        IATA_CODE_Reporting_Airline,\n        FlightDate,\n        count() AS Hops,\n        arraySort(\n            x -> (x.1, x.2, x.3),\n            groupArray((dep_ts, toString(Origin), toString(Dest), dep_hhmm))\n        ) AS ordered_legs,\n        arrayStringConcat(\n            arrayConcat([ordered_legs[1].2], arrayMap(x -> x.3, ordered_legs)),\n            ' -> '\n        ) AS Route,\n        arrayStringConcat(\n            arrayMap(x -> concat(x.4, ' ', x.2), ordered_legs),\n            ' | '\n        ) AS `Departure Times From Origin`\n    FROM legs\n    GROUP BY\n        Tail_Number,\n        Flight_Number_Reporting_Airline,\n        IATA_CODE_Reporting_Airline,\n        FlightDate\n),\nmax_hops AS (\n    SELECT max(Hops) AS value\n    FROM itineraries\n),\nscored AS (\n    SELECT\n        Tail_Number,\n        Flight_Number_Reporting_Airline,\n        IATA_CODE_Reporting_Airline,\n        FlightDate,\n        Hops,\n        Route,\n        `Departure Times From Origin`,\n        (SELECT value FROM max_hops) AS `Max Hops Overall`,\n        (SELECT count() FROM itineraries WHERE Hops = (SELECT value FROM max_hops)) AS `Max Hop Itinerary Count`,\n        count() OVER (PARTITION BY Hops, Route) AS `Same-Hops Route Count`\n    FROM itineraries\n),\ntop10 AS (\n    SELECT\n        Tail_Number,\n        Flight_Number_Reporting_Airline,\n        IATA_CODE_Reporting_Airline,\n        FlightDate,\n        Hops,\n        Route,\n        `Departure Times From Origin`,\n        `Max Hops Overall`,\n        `Max Hop Itinerary Count`,\n        `Same-Hops Route Count`\n    FROM scored\n    ORDER BY Hops DESC, FlightDate DESC, Tail_Number DESC\n    LIMIT 10\n)\nSELECT\n    Tail_Number AS `Aircraft ID`,\n    Flight_Number_Reporting_Airline AS `Flight Number`,\n    IATA_CODE_Reporting_Airline AS Carrier,\n    FlightDate AS Date,\n    Hops,\n    Route,\n    `Departure Times From Origin`,\n    `Max Hops Overall`,\n    `Max Hop Itinerary Count`,\n    `Same-Hops Route Count`,\n    count() OVER (PARTITION BY Route) AS `Route Frequency In Top 10`\nFROM top10\nORDER BY Hops DESC, Date DESC, `Aircraft ID` DESC",
  "report_markdown": "# Highest daily hops for one aircraft on one flight number\n\n{{data_overview_md}}\n\nThe key derived value is {{metric.primary_value}}.\n\n{{result_table_md}}\n\nThe maximum-hop result should be interpreted as {{metric.max_hop_pattern}}.\n\nThe single most recent itinerary among the maximum-hop rows is {{metric.most_recent_max_itinerary}}.\n\nAcross the top 10 longest itineraries, notable route repetition or clustering is {{metric.route_clustering_note}}.",
  "metrics": {
    "summary_facts": [
      "State the maximum value in `Hops` and whether `Max Hop Itinerary Count` indicates a repeated operating pattern or a one-off result.",
      "Identify the most recent row where `Hops` equals `Max Hops Overall`, and summarize the carrier, flight number, date, aircraft id, route, and `Departure Times From Origin`.",
      "Summarize route repetition across the top 10 using `Route Frequency In Top 10` and `Same-Hops Route Count`."
    ],
    "named_values": {
      "primary_value": "the maximum observed daily hop count in `Hops`",
      "max_hop_pattern": "whether the maximum-hop result is repeated or one-off based on `Max Hop Itinerary Count` and the repeated routes visible among the returned rows",
      "most_recent_max_itinerary": "the carrier, flight number, date, aircraft id, route, and departure timeline from the most recent row where `Hops` equals `Max Hops Overall`",
      "route_clustering_note": "the strongest route repetition or clustering pattern visible across the top 10 rows, using `Route Frequency In Top 10` and `Same-Hops Route Count`"
    },
    "named_lists": {
      "example_list": [
        "List the most repeated routes in the top 10 in descending `Route Frequency In Top 10` order."
      ]
    }
  }
}
