+            ' | '
+        ) AS Route
+    FROM
+    (
+        SELECT
+            FlightDate,
+            TailNum,
+            FlightNum,
+            Carrier,
+            arraySort(x -> x.1, groupArray((
+                dep_local_ts - toIntervalMinute(origin_offset_minutes),
+                dep_local_ts,
+                Origin,
+                Dest
+            ))) AS ordered_legs
+        FROM legs
