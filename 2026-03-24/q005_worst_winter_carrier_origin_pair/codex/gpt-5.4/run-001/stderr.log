tool altinity_ontime_demo.execute_query({"query":"WITH weak_pairs AS (SELECT Carrier, OriginCode, count() AS winter_flights, round(avg(if(DepDel15 = 0, 1.0, 0.0)) * 100, 2) AS dep_otp_pct, round(avg(ifNull(toFloat64(DepDelay), 0.0)), 2) AS avg_dep_delay_min FROM ontime.fact_ontime WHERE Month IN (12, 1, 2) AND Cancelled = 0 AND Diverted = 0 GROUP BY Carrier, OriginCode HAVING winter_flights >= 1000 ORDER BY dep_otp_pct ASC, avg_dep_delay_min DESC LIMIT 10), carrier_counts AS (SELECT Carrier, count() AS weak_pair_count, row_number() OVER (ORDER BY count() DESC, Carrier ASC) AS rk FROM weak_pairs GROUP BY Carrier), airport_counts AS (SELECT OriginCode, count() AS weak_pair_count, row_number() OVER (ORDER BY count() DESC, OriginCode ASC) AS rk FROM weak_pairs GROUP BY OriginCode) SELECT coalesce(toString(c.rk), toString(a.rk)) AS rank_slot, c.Carrier AS carrier, c.weak_pair_count AS carrier_weak_pair_count, a.OriginCode AS airport_code, a.weak_pair_count AS airport_weak_pair_count FROM carrier_counts AS c FULL OUTER JOIN airport_counts AS a ON c.rk = a.rk ORDER BY toUInt32(rank_slot)","limit":30})
