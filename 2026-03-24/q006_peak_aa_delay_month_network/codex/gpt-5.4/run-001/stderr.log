tool altinity_ontime_demo.execute_query({"query":"WITH toDate('2024-07-01') AS peak_month, origin_delay AS ( SELECT OriginCode, count() AS flight_volume, sum(DepDelayMinutes) AS total_departure_delay_minutes FROM ontime.fact_ontime WHERE Carrier = 'AA' AND Cancelled = 0 AND DepDelay IS NOT NULL AND toStartOfMonth(FlightDate) = peak_month GROUP BY OriginCode HAVING flight_volume >= 1000 ), route_delay AS ( SELECT concat(OriginCode, '-', DestCode) AS route, count() AS flight_volume, sum(DepDelayMinutes) AS total_departure_delay_minutes FROM ontime.fact_ontime WHERE Carrier = 'AA' AND Cancelled = 0 AND DepDelay IS NOT NULL AND toStartOfMonth(FlightDate) = peak_month GROUP BY route HAVING flight_volume >= 200 ), origin_ranked AS ( SELECT total_departure_delay_minutes, row_number() OVER (ORDER BY total_departure_delay_minutes DESC) AS rn, sum(total_departure_delay_minutes) OVER () AS total_delay_minutes FROM origin_delay ), route_ranked AS ( SELECT total_departure_delay_minutes, row_number() OVER (ORDER BY total_departure_delay_minutes DESC) AS rn, sum(total_departure_delay_minutes) OVER () AS total_delay_minutes FROM route_delay ) SELECT uniqExactIf(OriginCode, 1) AS total_origins_in_month, ( SELECT uniqExact(route) FROM ( SELECT concat(OriginCode, '-', DestCode) AS route FROM ontime.fact_ontime WHERE Carrier = 'AA' AND Cancelled = 0 AND DepDelay IS NOT NULL AND toStartOfMonth(FlightDate) = peak_month ) ) AS total_routes_in_month, round(( SELECT sum(total_departure_delay_minutes) FROM origin_ranked WHERE rn <= 2 ) * 100.0 / any(origin_ranked.total_delay_minutes), 2) AS top_2_origins_share_pct, round(( SELECT sum(total_departure_delay_minutes) FROM origin_ranked WHERE rn <= 5 ) * 100.0 / any(origin_ranked.total_delay_minutes), 2) AS top_5_origins_share_pct, round(( SELECT sum(total_departure_delay_minutes) FROM route_ranked WHERE rn <= 10 ) * 100.0 / any(route_ranked.total_delay_minutes), 2) AS top_10_routes_share_pct FROM ( SELECT OriginCode FROM ontime.fact_ontime WHERE Carrier = 'AA' AND Cancelled = 0 AND DepDelay IS NOT NULL AND toStartOfMonth(FlightDate) = peak_month GROUP BY OriginCode ) AS origins CROSS JOIN origin_ranked LIMIT 1","limit":10})
